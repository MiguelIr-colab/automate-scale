# ----------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------
PORT=8080
NODE_ENV=production

# Comma-separated list of allowed origins (CORS)
# Example: https://aiassistant-bots.ch,https://www.aiassistant-bots.ch,https://swissicoupons.com
ALLOWED_ORIGINS=https://aiassistant-bots.ch,https://www.aiassistant-bots.ch,https://swissicoupons.com,https://www.swissicoupons.com

# ----------------------------------------------------------------------
# Google reCAPTCHA v2/v3
# Site key (public, used in frontend): 6LfSMdIsAAAAALqAv_dNRvuYzzIARX61C-Ue63pN
# ----------------------------------------------------------------------
RECAPTCHA_SECRET=your_google_recaptcha_secret_here
# Minimum score for reCAPTCHA v3 (0.0 - 1.0). Ignored for v2.
RECAPTCHA_MIN_SCORE=0.5

# ----------------------------------------------------------------------
# SMTP / Email (Nodemailer)
# ----------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Where contact form submissions are delivered
EMAIL_TO=your_email@example.com
EMAIL_FROM="iAssistant Bots <your_email@example.com>"

# ----------------------------------------------------------------------
# Rate limiting
# ----------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5
